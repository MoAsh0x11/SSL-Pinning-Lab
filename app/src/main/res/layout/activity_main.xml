<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121418"
    tools:context=".MainActivity">

    <!-- Faint grid or border lines to mimic the background structure -->
    <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="#382A41"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="32dp" />

    <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="#382A41"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="32dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Cartoon/Comic Style Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SSL PINNING"
                android:textSize="48sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:textColor="#F4F4F0"
                android:shadowColor="#000000"
                android:shadowDx="8"
                android:shadowDy="8"
                android:shadowRadius="1"
                android:letterSpacing="-0.03"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="-16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LABORATORY"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:textColor="#139090"
                android:shadowColor="#000000"
                android:shadowDx="6"
                android:shadowDy="6"
                android:shadowRadius="1"
                android:letterSpacing="0.02"
                android:layout_marginBottom="12dp" />

            <!-- Cartoon/Retro Buttons -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCustomTrust"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/comic_button"
                android:text="CUSTOM TRUST MANAGER"
                android:textColor="#121418"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:paddingBottom="6dp"
                android:paddingEnd="6dp"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnOkHttpPinner"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/comic_button"
                android:text="OKHTTP PINNER"
                android:textColor="#121418"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:paddingBottom="6dp"
                android:paddingEnd="6dp"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnNsc"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/comic_button"
                android:text="NETWORK SECURITY CONFIG"
                android:textColor="#121418"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:paddingBottom="6dp"
                android:paddingEnd="6dp"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnNativePinning"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/comic_button"
                android:text="NATIVE NDK PINNING"
                android:textColor="#121418"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:paddingBottom="6dp"
                android:paddingEnd="6dp"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCt"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/comic_button"
                android:text="CERTIFICATE TRANSPARENCY"
                android:textColor="#121418"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:paddingBottom="6dp"
                android:paddingEnd="6dp"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnInterceptor"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/comic_button"
                android:text="OKHTTP INTERCEPTOR"
                android:textColor="#121418"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:paddingBottom="6dp"
                android:paddingEnd="6dp"
                android:layout_marginBottom="12dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Fullscreen Noise Overlay (Cartoony/Printed texture) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/repeating_noise"
        android:scaleType="fitXY"
        android:alpha="0.4"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no" />

</androidx.constraintlayout.widget.ConstraintLayout>